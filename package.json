{
  "name": "raxee-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "dev": "tsx watch bin/bot.ts",
    "lint": "eslint .",
    "lint:ci": "DEBUG=eslint:eslint eslint .",
    "prettier": "prettier --write '**/*.(ts|js|md|json)'",
    "prettier:ci": "prettier --check '**/*.(ts|js|md|json)'",
    "prisma": "prisma --config prisma/config.ts",
    "start": "tsx bin/bot.ts",
    "test": "vitest run --coverage --coverage.include='**/*.ts'",
    "test:ci": "prisma generate && vitest run",
    "test:codecov": "prisma generate && npx vitest run --coverage --coverage.include='**/*.ts'"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/runner": "^2.0.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@telegram-md/core": "^1.0.0",
    "@telegram-md/grammy-plugin": "^1.0.0",
    "@types/node": "^24.12.4",
    "@vlad-iakovlev/poker": "^1.5.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.42.0",
    "prisma": "^7.8.0",
    "remeda": "^2.34.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@napi-rs/wasm-runtime": "^1.1.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vlad-iakovlev/eslint-config": "^1.2.0",
    "eslint": "^10.4.0",
    "jiti": "^2.7.0",
    "lefthook": "^2.1.6",
    "magicast": "0.3.5",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  }
}
